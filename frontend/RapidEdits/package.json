{
    "name": "desktop",
    "private": true,
    "version": "0.1.0",
    "main": "dist-electron/main.js",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
        "dev:renderer": "vite",
        "dev:electron": "wait-on tcp:7000 && cross-env VITE_DEV_SERVER_URL=http://localhost:7000 electron .",
        "electron:dev": "npm run dev",
        "dev:electron:standalone": "electron .",
        "start": "electron .",
        "build": "vue-tsc --noEmit && vite build && electron-builder",
        "preview": "vite preview",
        "typecheck": "vue-tsc --noEmit",
        "lint": "eslint .",
        "format": "prettier --write \"src/**/*.ts\" \"src/**/*.vue\""
    },
    "build": {
        "appId": "com.rapidedits.app",
        "productName": "RapidEdits",
        "directories": {
            "output": "release/${version}"
        },
        "files": [
            "dist",
            "dist-electron"
        ],
        "win": {
            "target": [
                "portable"
            ]
        }
    },
    "dependencies": {
        "@firecms/neat": "^0.6.0",
        "@huggingface/transformers": "^3.0.0",
        "@types/three": "^0.181.0",
        "@types/uuid": "^10.0.0",
        "@vueuse/core": "^14.2.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "idb": "^8.0.3",
        "lucide-vue-next": "^0.577.0",
        "mediabunny": "^1.39.2",
        "pinia": "^3.0.4",
        "reka-ui": "^2.9.2",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "three": "^0.182.0",
        "three-stdlib": "^2.36.1",
        "uiohook-napi": "^1.5.4",
        "uuid": "^13.0.0",
        "vue": "^3.5.30",
        "vue-router": "^5.0.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.12.0",
        "@types/three": "0.182.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.0",
        "autoprefixer": "^10.4.27",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^41.0.2",
        "electron-builder": "^26.8.1",
        "eslint": "^10.0.3",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.4.0",
        "playwright": "^1.58.2",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "tailwindcss": "^3.4.17",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.0",
        "vue-tsc": "^3.1.1",
        "wait-on": "^9.0.4",
        "vite-plugin-electron": "^0.29.0",
        "vite-plugin-electron-renderer": "^0.14.6"
    }
}
